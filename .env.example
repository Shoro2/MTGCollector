# MTG Collector — environment variables
# Copy to .env and fill in the values. Never commit .env.

# ------------------------------------------------------------------
# Required: Google OAuth (console.cloud.google.com/apis/credentials)
# Authorized redirect URI: {ORIGIN}/auth/callback/google
# ------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ORIGIN=http://localhost:5173

# ------------------------------------------------------------------
# Optional: the user whose account is treated as the admin. Must match
# the email on their Google profile (case-insensitive).
# ------------------------------------------------------------------
ADMIN_EMAIL=

# ------------------------------------------------------------------
# Optional: Cloudflare Turnstile for the /contact form. Leave blank to
# disable bot protection on that form.
# ------------------------------------------------------------------
TURNSTILE_SECRET_KEY=

# ------------------------------------------------------------------
# Notes
# ------------------------------------------------------------------
# - The Google Vision API key is stored per-user in the database, not
#   as an env var. Each user sets theirs at /settings.
# - The AES key used to encrypt per-user secrets lives in
#   data/secret-key.hex and is generated on first use. Back it up
#   together with the database.
